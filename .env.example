# Nairobi Urban Intelligence — environment config
# Copy this to .env and fill in values (no secrets required for OSM data)

# DuckDB file path (relative to project root)
DUCKDB_PATH=data/nairobi.duckdb

# GeoPackage output path
GPKG_PATH=data/nairobi_pois.gpkg

# Overpass API settings
OVERPASS_RATE_LIMIT=False
OVERPASS_MAX_QUERY_AREA_SIZE=2500000000

# OSMnx place name
PLACE_NAME=Nairobi, Kenya

# DBSCAN parameters
DBSCAN_EPS=0.005
DBSCAN_MIN_SAMPLES=3

# Service desert threshold (km)
SERVICE_DESERT_KM=2.0

# dbt project directory (relative to project root)
DBT_PROJECT_DIR=dbt
DBT_PROFILES_DIR=dbt
