# Nairobi Urban Intelligence — environment config
# Copy this to .env and fill in values (no secrets required for OSM data)

# DuckDB file path (relative to project root — used by Python scripts)
DUCKDB_PATH=data/nairobi.duckdb

# GeoPackage output path
GPKG_PATH=data/nairobi_pois.gpkg

# Overpass API settings
OVERPASS_RATE_LIMIT=False
OVERPASS_MAX_QUERY_AREA_SIZE=2500000000

# OSMnx place name
PLACE_NAME=Nairobi, Kenya

# DBSCAN parameters
# DBSCAN_EPS is in decimal degrees (0.005° ≈ 556 m at the equator).
# The code converts this to radians internally for sklearn's haversine metric.
DBSCAN_EPS=0.005
DBSCAN_MIN_SAMPLES=3

# Service desert threshold (km)
SERVICE_DESERT_KM=2.0

# dbt project directory (relative to project root)
DBT_PROJECT_DIR=dbt
DBT_PROFILES_DIR=dbt

# Absolute path to the DuckDB file — set automatically by run.ps1 / run.sh
# so that dbt profiles.yml resolves the path correctly when run from dbt/.
# If running dbt manually, set this to the full absolute path, e.g.:
#   Linux/macOS: DUCKDB_PATH_ABS=/path/to/project/data/nairobi.duckdb
#   Windows:     DUCKDB_PATH_ABS=C:\path\to\project\data\nairobi.duckdb
# DUCKDB_PATH_ABS=
